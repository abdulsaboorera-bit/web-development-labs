<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Products</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background: #f4f4f4;
        margin: 0;
        padding: 24px;
      }
      .container {
        max-width: 1000px;
        margin: 0 auto;
        background: #fff;
        padding: 20px;
        border-radius: 8px;
      }
      h1 {
        margin-top: 0;
      }
      .filters {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        gap: 12px;
        margin-bottom: 16px;
      }
      .filters label {
        display: flex;
        flex-direction: column;
        font-size: 13px;
        color: #2f3b3b;
        gap: 6px;
      }
      .filters input,
      .filters select {
        padding: 8px 10px;
        border: 1px solid #d2d2d2;
        border-radius: 6px;
      }
      .filters button {
        padding: 10px 12px;
        border: none;
        border-radius: 6px;
        background: #2e7272;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
        margin-top: 18px;
      }
      .grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 14px;
      }
      .card {
        border: 1px solid #e2e2e2;
        border-radius: 8px;
        padding: 12px;
        background: #fafafa;
      }
      .card h3 {
        margin: 0 0 6px 0;
        font-size: 16px;
      }
      .meta {
        font-size: 13px;
        color: #4d4d4d;
        margin: 4px 0;
      }
      .pagination {
        display: flex;
        gap: 8px;
        justify-content: center;
        margin-top: 20px;
        flex-wrap: wrap;
      }
      .pagination a,
      .pagination span {
        padding: 6px 10px;
        border-radius: 6px;
        border: 1px solid #d2d2d2;
        text-decoration: none;
        color: #2f3b3b;
      }
      .pagination .active {
        background: #2e7272;
        color: #fff;
        border-color: #2e7272;
      }
      .summary {
        margin: 8px 0 16px;
        color: #4d4d4d;
        font-size: 13px;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <h1>Product Catalog</h1>
      <p class="summary">Showing <%= products.length %> of <%= total %> products</p>

      <form class="filters" method="get" action="/products">
        <label>
          Search
          <input type="text" name="search" value="<%= search %>" placeholder="Product name" />
        </label>
        <label>
          Category
          <select name="category">
            <option value="">All</option>
            <% categories.forEach(function(cat) { %>
              <option value="<%= cat %>" <%= cat === category ? "selected" : "" %>><%= cat %></option>
            <% }); %>
          </select>
        </label>
        <label>
          Min Price
          <input type="number" name="minPrice" step="0.01" value="<%= minPrice %>" />
        </label>
        <label>
          Max Price
          <input type="number" name="maxPrice" step="0.01" value="<%= maxPrice %>" />
        </label>
        <label>
          Sort
          <select name="sort">
            <option value="">Name (A-Z)</option>
            <option value="price-asc" <%= sort === "price-asc" ? "selected" : "" %>>Price: Low to High</option>
            <option value="price-desc" <%= sort === "price-desc" ? "selected" : "" %>>Price: High to Low</option>
            <option value="rating-desc" <%= sort === "rating-desc" ? "selected" : "" %>>Rating: High to Low</option>
          </select>
        </label>
        <button type="submit">Apply</button>
      </form>

      <div class="grid">
        <% products.forEach(function(product) { %>
          <div class="card">
            <h3><%= product.name %></h3>
            <div class="meta">Category: <%= product.category %></div>
            <div class="meta">Price: $<%= product.price.toFixed(2) %></div>
            <div class="meta">Rating: <%= product.rating %></div>
            <div class="meta">Stock: <%= product.stock %></div>
          </div>
        <% }); %>
      </div>

      <div class="pagination">
        <% if (page > 1) { %>
          <a href="/products?page=<%= page - 1 %><%= queryString ? "&" + queryString : "" %>">Previous</a>
        <% } %>
        <% for (let p = 1; p <= totalPages; p++) { %>
          <% if (p === page) { %>
            <span class="active"><%= p %></span>
          <% } else { %>
            <a href="/products?page=<%= p %><%= queryString ? "&" + queryString : "" %>"><%= p %></a>
          <% } %>
        <% } %>
        <% if (page < totalPages) { %>
          <a href="/products?page=<%= page + 1 %><%= queryString ? "&" + queryString : "" %>">Next</a>
        <% } %>
      </div>
    </div>
  </body>
</html>
