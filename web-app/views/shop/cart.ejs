<div class="container page-header">
  <h2>Your Cart</h2>
</div>

<div class="container cart-container">
  <% if (cartItems.length > 0) { %>
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 2rem;">
      <thead>
        <tr style="border-bottom: 2px solid #e2e8f0; text-align: left;">
          <th style="padding: 1rem;">Product</th>
          <th style="padding: 1rem;">Price</th>
          <th style="padding: 1rem;">Quantity</th>
          <th style="padding: 1rem;">Total</th>
          <th style="padding: 1rem;">Action</th>
        </tr>
      </thead>
      <tbody>
        <% cartItems.forEach(item => { %>
          <tr style="border-bottom: 1px solid #e2e8f0;">
            <td style="padding: 1rem; display: flex; align-items: center; gap: 1rem;">
              <img src="<%= item.product.image %>" alt="<%= item.product.name %>" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">
              <span><%= item.product.name %></span>
            </td>
            <td style="padding: 1rem;">$<%= item.product.price.toFixed(2) %></td>
            <td style="padding: 1rem;"><%= item.quantity %></td>
            <td style="padding: 1rem;">$<%= (item.product.price * item.quantity).toFixed(2) %></td>
            <td style="padding: 1rem;">
              <form action="/cart/remove/<%= item.product._id %>" method="POST" style="display: inline;">
                <button type="submit" style="background: none; border: none; color: #e53e3e; cursor: pointer; text-decoration: underline;">Remove</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    
    <div style="display: flex; justify-content: space-between; align-items: center;">
      <h3>Total: $<%= total.toFixed(2) %></h3>
      <a href="/checkout" class="btn btn-primary" style="padding: 1rem 2rem;">Proceed to Checkout</a>
    </div>
  <% } else { %>
    <div class="empty-state" style="text-align: center; padding: 3rem;">
      <h3>Your cart is empty</h3>
      <p>Go back to the <a href="/shop">shop</a> to add some products.</p>
    </div>
  <% } %>
</div>
