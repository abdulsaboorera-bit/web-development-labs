<div style="display: grid; grid-template-columns: 2fr 1fr; gap: 2rem;">
  <!-- Order Items -->
  <div class="admin-card">
    <h3 style="margin-bottom: 1.5rem;">Order Items</h3>
    <table class="admin-table">
      <thead>
        <tr>
          <th>Product</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total</th>
        </tr>
      </thead>
      <tbody>
        <% order.items.forEach(item => { %>
          <tr>
            <td>
              <% if (item.product) { %>
                <%= item.product.name %>
              <% } else { %>
                <span style="color: #94a3b8;">(Product Deleted)</span>
              <% } %>
            </td>
            <td>$<%= item.price.toFixed(2) %></td>
            <td><%= item.quantity %></td>
            <td>$<%= (item.price * item.quantity).toFixed(2) %></td>
          </tr>
        <% }) %>
      </tbody>
      <tfoot>
        <tr style="font-weight: 700; font-size: 1.1rem;">
          <td colspan="3" style="text-align: right; padding: 1rem;">Total Amount:</td>
          <td style="padding: 1rem;">$<%= order.total.toFixed(2) %></td>
        </tr>
      </tfoot>
    </table>
  </div>

  <!-- Order Info & Status Update -->
  <div>
    <div class="admin-card">
      <h3 style="margin-bottom: 1.5rem;">Customer Info</h3>
      <p><strong>Name:</strong> <%= order.user.name %></p>
      <p><strong>Email:</strong> <%= order.user.email %></p>
      
      <h3 style="margin: 1.5rem 0 1rem 0;">Shipping Info</h3>
      <p><%= order.shippingInfo.address %></p>
      <p><%= order.shippingInfo.city %>, <%= order.shippingInfo.zip %></p>
    </div>

    <div class="admin-card">
      <h3 style="margin-bottom: 1.5rem;">Order Status</h3>
      <form action="/admin/orders/status/<%= order._id %>" method="POST">
        <div class="form-group">
          <select name="status" class="form-control">
            <option value="pending" <%= order.status === 'pending' ? 'selected' : '' %>>Pending</option>
            <option value="shipped" <%= order.status === 'shipped' ? 'selected' : '' %>>Shipped</option>
            <option value="delivered" <%= order.status === 'delivered' ? 'selected' : '' %>>Delivered</option>
            <option value="cancelled" <%= order.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
          </select>
        </div>
        <button type="submit" class="btn btn-primary" style="width: 100%;">Update Status</button>
      </form>
    </div>
  </div>
</div>

<div style="margin-top: 1rem;">
  <a href="/admin/orders" class="btn btn-secondary">Back to Orders</a>
</div>
