<div class="admin-card">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h3 style="margin: 0;">Product Inventory</h3>
    <a href="/admin/products/new" class="btn btn-primary">Add New Product</a>
  </div>

  <table class="admin-table">
    <thead>
      <tr>
        <th>Image</th>
        <th>
          <a href="/admin/products?sort=name&order=<%= sortField === 'name' && sortOrder === 'asc' ? 'desc' : 'asc' %>" style="color: inherit; text-decoration: none;">
            Name <%= sortField === 'name' ? (sortOrder === 'asc' ? '↑' : '↓') : '' %>
          </a>
        </th>
        <th>
          <a href="/admin/products?sort=price&order=<%= sortField === 'price' && sortOrder === 'asc' ? 'desc' : 'asc' %>" style="color: inherit; text-decoration: none;">
            Price <%= sortField === 'price' ? (sortOrder === 'asc' ? '↑' : '↓') : '' %>
          </a>
        </th>
        <th>Category</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (products && products.length > 0) { %>
        <% products.forEach(product => { %>
          <tr>
            <td>
              <img src="<%= product.image %>" alt="<%= product.name %>" style="width: 50px; height: 50px; object-fit: cover; border-radius: 4px;">
            </td>
            <td><strong><%= product.name %></strong></td>
            <td>$<%= product.price.toFixed(2) %></td>
            <td>
              <span class="badge" style="background: #e2e8f0; color: #475569;">
                <%= product.category ? product.category.name : 'Uncategorized' %>
              </span>
            </td>
            <td>
              <div style="display: flex; gap: 0.5rem;">
                <a href="/admin/products/edit/<%= product._id %>" class="btn btn-sm btn-secondary" title="Edit">
                  <i class="fas fa-edit"></i>
                </a>
                <form action="/admin/products/delete/<%= product._id %>" method="POST" onsubmit="return confirm('Are you sure?')">
                  <button type="submit" class="btn btn-sm" style="background: #ef4444; color: white;" title="Delete">
                    <i class="fas fa-trash"></i>
                  </button>
                </form>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="5" style="text-align: center; padding: 2rem; color: #94a3b8;">No products found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>

  <% if (totalPages > 1) { %>
    <div style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 1.5rem;">
      <% if (currentPage > 1) { %>
        <a href="/admin/products?page=<%= currentPage - 1 %>&sort=<%= sortField %>&order=<%= sortOrder %>" class="btn btn-sm btn-secondary">Prev</a>
      <% } %>
      
      <% for(let i=1; i<=totalPages; i++) { %>
        <a href="/admin/products?page=<%= i %>&sort=<%= sortField %>&order=<%= sortOrder %>" 
           class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-secondary' %>">
          <%= i %>
        </a>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="/admin/products?page=<%= currentPage + 1 %>&sort=<%= sortField %>&order=<%= sortOrder %>" class="btn btn-sm btn-secondary">Next</a>
      <% } %>
    </div>
  <% } %>
</div>
