<div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1.5rem; margin-top: 1rem;">
  <!-- Products Stat -->
  <div class="admin-card" style="text-align: center;">
    <div style="font-size: 2rem; color: #cbd5e1; margin-bottom: 1rem;"><i class="fas fa-box"></i></div>
    <h3 style="color: var(--text-muted); font-size: 0.875rem; text-transform: uppercase; margin-bottom: 1rem;">Total Products</h3>
    <p style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem;"><%= productCount %></p>
    <a href="/admin/products" class="btn btn-sm btn-secondary">Manage Products</a>
  </div>

  <!-- Categories Stat -->
  <div class="admin-card" style="text-align: center;">
    <div style="font-size: 2rem; color: #cbd5e1; margin-bottom: 1rem;"><i class="fas fa-tags"></i></div>
    <h3 style="color: var(--text-muted); font-size: 0.875rem; text-transform: uppercase; margin-bottom: 1rem;">Total Categories</h3>
    <p style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--success);"><%= categoryCount %></p>
    <a href="/admin/categories" class="btn btn-sm btn-secondary">Manage Categories</a>
  </div>

  <!-- Orders Stat -->
  <div class="admin-card" style="text-align: center;">
    <div style="font-size: 2rem; color: #cbd5e1; margin-bottom: 1rem;"><i class="fas fa-shopping-cart"></i></div>
    <h3 style="color: var(--text-muted); font-size: 0.875rem; text-transform: uppercase; margin-bottom: 1rem;">Total Orders</h3>
    <p style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: var(--primary);"><%= orderCount %></p>
    <a href="/admin/orders" class="btn btn-sm btn-secondary">Manage Orders</a>
  </div>

  <!-- Users Stat -->
  <div class="admin-card" style="text-align: center;">
    <div style="font-size: 2rem; color: #cbd5e1; margin-bottom: 1rem;"><i class="fas fa-users"></i></div>
    <h3 style="color: var(--text-muted); font-size: 0.875rem; text-transform: uppercase; margin-bottom: 1rem;">Total Users</h3>
    <p style="font-size: 2.5rem; font-weight: 700; margin-bottom: 1rem; color: #d69e2e;"><%= userCount %></p>
  </div>
</div>
