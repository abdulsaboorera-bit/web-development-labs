<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'MERN E-Commerce' %></title>
  <link rel="stylesheet" href="/css/style.css">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;600;700&family=Source+Sans+3:wght@300;400;600;700&display=swap" rel="stylesheet">
</head>
<body>
  <div class="top-bar">Get Free Shipping on orders above 1999/-</div>
  <header class="site-header">
    <div class="container header-inner">
      <div class="header-top">
        <div class="header-spacer" aria-hidden="true"></div>
        <a href="/" class="logo-link" aria-label="Daari Mooch">
          <img src="/images/logo.png" alt="Daari Mooch" class="logo-img">
        </a>
        <div class="header-actions" aria-label="Account and cart">
          <a href="/cart">Cart (<%= typeof cartCount !== 'undefined' ? cartCount : 0 %>)</a>
          <% if (user) { %>
            <% if (user.role === 'admin') { %>
              <a href="/admin">Admin Panel</a>
            <% } %>
            <a href="/auth/logout">Logout (<%= user.name %>)</a>
          <% } else { %>
            <a href="/auth/login">Login</a>
            <a href="/auth/register">Register</a>
          <% } %>
        </div>
      </div>
      <nav class="main-nav" aria-label="Primary">
        <ul class="nav-row">
          <li><a href="/shop">Categories</a></li>
          <li><a href="#">Ramadan Bundle</a></li>
          <li><a href="#">Beard</a></li>
          <li><a href="#">Face</a></li>
          <li><a href="#">Hair</a></li>
          <li><a href="#">De-Tan Line</a></li>
          <li><a href="#">build your Own Bundle</a></li>
          <li><a href="#">Royalty Rewards</a></li>
          <li><a href="#">Dari Mooch Barber Shop</a></li>
          <li><a href="#">Best Sellers</a></li>
          <li><a href="#">Deals</a></li>
        </ul>
        <ul class="nav-row">
          <li><a href="#">Best Sellers</a></li>
          <li><a href="#">Deals</a></li>
          <li><a href="#">Gifts</a></li>
          <li><a href="/shop">All Products</a></li>
          <li><a href="#">Blog</a></li>
          <li><a href="#">Order Tracker</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <div class="container" style="margin-top: 1rem;">
    <% if (success_msg && success_msg.length > 0) { %>
      <% success_msg.forEach(msg => { %>
        <div style="background: #c6f6d5; color: #22543d; padding: 1rem; border-radius: 4px; margin-bottom: 1rem;">
          <%= msg %>
        </div>
      <% }) %>
    <% } %>
    <% if (error_msg && error_msg.length > 0) { %>
      <% error_msg.forEach(msg => { %>
        <div style="background: #fed7d7; color: #822727; padding: 1rem; border-radius: 4px; margin-bottom: 1rem;">
          <%= msg %>
        </div>
      <% }) %>
    <% } %>
  </div>

  <main class="main-content">
    <%- body %>
  </main>

  <div id="newsletter">
    <h1>Newsletter</h1>
    <p>
      Let your customers know what to expect if they sign up to your mailing
    </p>
    <p>A discount code or the latest news from your brand.</p>
    <div>
      <input type="text" placeholder="Email@example" id="news-input" />
      <button>Subscribe</button>
    </div>
  </div>

  <div id="shop-chatbot" class="shop-chatbot">
    <button type="button" class="shop-chatbot-toggle" id="shop-chatbot-toggle" aria-expanded="false" aria-controls="shop-chatbot-panel">
      AI
    </button>
    <div class="shop-chatbot-panel" id="shop-chatbot-panel">
      <div class="shop-chatbot-header">AI Assistant</div>
      <div class="shop-chatbot-messages" id="shop-chatbot-messages">
        <div class="shop-chatbot-message bot">Hi! Ask me about products or categories.</div>
      </div>
      <form class="shop-chatbot-input" id="shop-chatbot-form">
        <input type="text" id="shop-chatbot-text" placeholder="Ask something..." aria-label="Ask the AI assistant" />
        <button type="submit">Send</button>
      </form>
    </div>
  </div>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div class="footer-col">
        <h4>Categories</h4>
        <ul>
          <li><a href="/shop">Categories</a></li>
          <li><a href="#">Ramdan Bundles</a></li>
          <li><a href="#">Hair</a></li>
          <li><a href="#">Face</a></li>
          <li><a href="#">Beard</a></li>
          <li><a href="#">De-Tan Line</a></li>
          <li><a href="#">Build Your Own Bundle</a></li>
          <li><a href="#">Loyalty Rewards</a></li>
          <li><a href="#">Dari Mooch Barber Shop</a></li>
          <li><a href="#">Best Sellers</a></li>
          <li><a href="#">Deals</a></li>
          <li><a href="#">Gifts</a></li>
          <li><a href="/shop">All Products</a></li>
          <li><a href="#">Blog</a></li>
          <li><a href="#">Order Tracker</a></li>
        </ul>
      </div>
      <div class="footer-col">
        <h4>Quick Links</h4>
        <ul>
          <li><a href="#">Track Your Order</a></li>
          <li><a href="#">Search</a></li>
          <li><a href="#">About us</a></li>
          <li><a href="#">Be Our Distributor</a></li>
          <li><a href="#">FAQ</a></li>
          <li><a href="#">Careers</a></li>
          <li><a href="#">Contact Us</a></li>
          <li><a href="#">Privacy Policy</a></li>
          <li><a href="#">Refund Policy</a></li>
          <li><a href="#">Terms of Service</a></li>
          <li><a href="#">Other Stores</a></li>
        </ul>
      </div>
      <div class="footer-col footer-bio">
        <h4>Mini Bio</h4>
        <p>
          Dari Mooch is a one stop solution for all your grooming needs. We’re the best at what we do and we leave no man behind. We're on a mission to style and groom every Pakistani man to their best self!
        </p>
        <h4>Store Locations:</h4>
        <ul>
          <li>Shapes Executive Gym Gulberg-III, Lahore</li>
          <li>Lake City Mall 1st floor, Lahore</li>
          <li>Packages Mall 2nd Floor Opposite Outfitters, Lahore</li>
          <li>Ground Floor Dari Mooch Kiosk Opposite Cougar Giga Mall Islamabad</li>
          <li>Barber Shop: Plaza # 30C, DHA Phase 4 Sector CCA DHA, Lahore</li>
        </ul>
      </div>
      <div class="footer-col footer-contact">
        <h4>Contact</h4>
        <p><a href="mailto:support@darimooch.com">support@darimooch.com</a></p>
        <p class="footer-phone"><a href="tel:+923161115556">+92 316 1115556</a></p>
        <div class="footer-socials">
          <a href="#" aria-label="Facebook">Facebook</a>
          <a href="#" aria-label="Instagram">Instagram</a>
          <a href="#" aria-label="TikTok">TikTok</a>
          <a href="#" aria-label="YouTube">YouTube</a>
        </div>
      </div>
    </div>
    <div class="footer-bottom">
      <div class="container footer-bottom-inner">
        <span>Powered By Shopify</span>
        <span>© 2024 Dari Mooch.</span>
      </div>
    </div>
  </footer>

  <script src="/js/chatbot.js"></script>
</body>
</html>
