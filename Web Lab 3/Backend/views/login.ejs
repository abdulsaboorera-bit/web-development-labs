<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
    <style>
      body {
        font-family: Arial, sans-serif;
        background: #f4f4f4;
        margin: 0;
        padding: 24px;
      }
      .container {
        max-width: 420px;
        margin: 0 auto;
        background: #fff;
        padding: 20px;
        border-radius: 8px;
      }
      .nav {
        display: flex;
        justify-content: space-between;
        margin-bottom: 16px;
      }
      .nav a {
        text-decoration: none;
        color: #2f3b3b;
        font-size: 14px;
      }
      label {
        display: block;
        margin-bottom: 10px;
        font-size: 13px;
        color: #2f3b3b;
      }
      input {
        width: 100%;
        padding: 8px 10px;
        border: 1px solid #d2d2d2;
        border-radius: 6px;
        margin-top: 6px;
      }
      button {
        width: 100%;
        padding: 10px 12px;
        border: none;
        border-radius: 6px;
        background: #2e7272;
        color: #fff;
        font-weight: 700;
        cursor: pointer;
      }
      .flash {
        padding: 10px 12px;
        border-radius: 6px;
        margin-bottom: 12px;
        font-size: 13px;
      }
      .flash-success {
        background: #e6f4f1;
        color: #1f5d57;
      }
      .flash-error {
        background: #ffe7e7;
        color: #a02a2a;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="nav">
        <a href="/products">Products</a>
        <a href="/register">Register</a>
      </div>
      <% if (success && success.length) { %>
        <div class="flash flash-success"><%= success[0] %></div>
      <% } %>
      <% if (error && error.length) { %>
        <div class="flash flash-error"><%= error[0] %></div>
      <% } %>
      <h1>Login</h1>
      <form method="post" action="/login">
        <label>
          Email
          <input type="email" name="email" required />
        </label>
        <label>
          Password
          <input type="password" name="password" required />
        </label>
        <button type="submit">Login</button>
      </form>
    </div>
  </body>
</html>
